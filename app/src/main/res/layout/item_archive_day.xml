<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/bg_log"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Date + result badge -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1.4" android:orientation="vertical">
            <TextView
                android:id="@+id/archDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/archHrs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Scores -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:text="YOU" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="@color/text_muted"
                android:textSize="9sp" android:gravity="center"/>
            <TextView android:id="@+id/archUser"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/good" android:textSize="18sp"
                android:textStyle="bold" android:fontFamily="monospace"
                android:gravity="center"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="vs" android:textColor="@color/text_muted"
            android:textSize="10sp" android:paddingHorizontal="6dp"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:text="ALEX" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="@color/text_muted"
                android:textSize="9sp" android:gravity="center"/>
            <TextView android:id="@+id/archRival"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/accent" android:textSize="18sp"
                android:textStyle="bold" android:fontFamily="monospace"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Gap + badge -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1.2" android:orientation="vertical"
            android:gravity="center" android:layout_marginStart="8dp">
            <TextView
                android:id="@+id/archResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"/>
            <TextView
                android:id="@+id/archGap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>
            <TextView
                android:id="@+id/archBoost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
