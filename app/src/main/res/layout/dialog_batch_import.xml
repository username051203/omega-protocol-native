<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/bg_card">

    <TextView android:text="One entry per line:"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="@color/text_muted" android:textSize="11sp"
        android:layout_marginBottom="4dp"/>
    <TextView android:text="Chapter Name, Topic Name"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="@color/accent" android:textSize="11sp"
        android:fontFamily="monospace" android:layout_marginBottom="10dp"/>

    <EditText android:id="@+id/etBatchInput"
        android:layout_width="match_parent" android:layout_height="120dp"
        android:gravity="top" android:inputType="textMultiLine"
        android:background="@color/bg_log" android:textColor="@color/text_primary"
        android:textSize="11sp" android:fontFamily="monospace"
        android:padding="10dp"
        android:hint="General Microbiology, Scientists &amp; Stains&#10;Virology, DNA Virus Pt 1"/>

</LinearLayout>
