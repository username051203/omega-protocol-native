<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:background="@color/bg_card"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="bottom">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- User -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/navHeaderUserAvatar"
                android:layout_width="52dp" android:layout_height="52dp"
                android:src="@drawable/ic_avatar_placeholder"
                app:civ_border_color="@color/good" app:civ_border_width="2dp"/>
            <TextView android:id="@+id/navHeaderUserName"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="YOU" android:textColor="@color/good"
                android:textSize="10sp" android:textStyle="bold"
                android:layout_marginTop="4dp" android:fontFamily="monospace"
                android:letterSpacing="0.1"/>
        </LinearLayout>

        <!-- VS -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="VS" android:textColor="@color/accent2"
            android:textSize="14sp" android:textStyle="bold"
            android:paddingHorizontal="12dp" android:fontFamily="monospace"/>

        <!-- Rival -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/navHeaderRivalAvatar"
                android:layout_width="52dp" android:layout_height="52dp"
                android:src="@drawable/ic_avatar_placeholder"
                app:civ_border_color="@color/accent" app:civ_border_width="2dp"/>
            <TextView android:id="@+id/navHeaderRivalName"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ALEXANDRIUS" android:textColor="@color/accent"
                android:textSize="10sp" android:textStyle="bold"
                android:layout_marginTop="4dp" android:fontFamily="monospace"
                android:letterSpacing="0.1"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="OMEGA PROTOCOL" android:textColor="@color/text_muted"
        android:textSize="9sp" android:fontFamily="monospace"
        android:letterSpacing="0.2" android:layout_marginTop="12dp"/>
</LinearLayout>
