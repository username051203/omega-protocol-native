<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- EOD Report Card (hidden by default) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardEod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <TextView android:text="📊 END OF DAY REPORT"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/accent" android:textSize="13sp"
                    android:fontFamily="monospace" android:letterSpacing="0.1"
                    android:gravity="center" android:textStyle="bold"/>
                <TextView android:id="@+id/tvEodDate"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_muted" android:textSize="11sp"
                    android:gravity="center" android:layout_marginTop="4dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="16dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@color/bg_log" android:padding="12dp">
                        <TextView android:text="YOUR PASSES" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:textColor="@color/text_muted"
                            android:textSize="9sp" android:gravity="center"/>
                        <TextView android:id="@+id/tvEodUserCh" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:textColor="@color/good"
                            android:textSize="28sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:gravity="center"/>
                    </LinearLayout>
                    <View android:layout_width="8dp" android:layout_height="match_parent"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@color/bg_log" android:padding="12dp">
                        <TextView android:text="ALEXANDRIUS" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:textColor="@color/text_muted"
                            android:textSize="9sp" android:gravity="center"/>
                        <TextView android:id="@+id/tvEodRivalCh" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:textColor="@color/accent"
                            android:textSize="28sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:gravity="center"/>
                    </LinearLayout>
                </LinearLayout>
                <TextView android:id="@+id/tvEodResult"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" android:padding="12dp"
                    android:gravity="center" android:textSize="14sp" android:textStyle="bold"
                    android:letterSpacing="0.05" android:textColor="@color/text_primary"/>
                <TextView android:id="@+id/tvEodGap"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textSize="12sp" android:gravity="center"/>
                <TextView android:id="@+id/tvEodBoost"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="@color/text_muted"
                    android:gravity="center" android:layout_marginTop="2dp"/>
                <TextView android:id="@+id/tvEodBudget"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="@color/text_muted"
                    android:gravity="center" android:layout_marginTop="2dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="12dp">
                    <Button android:id="@+id/btnShareEod"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="📤 Share Report"
                        android:backgroundTint="@color/bg_log"
                        android:textColor="#90b8ff" android:textSize="12sp"
                        android:layout_marginEnd="8dp"/>
                    <Button android:id="@+id/btnCloseEod"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="✕ Close"
                        android:backgroundTint="@color/bg_card"
                        android:textColor="@color/text_muted" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Main status card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="6dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tvClock"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="--:--" android:textColor="@color/warn"
                            android:textSize="34sp" android:fontFamily="monospace" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvStatus"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="System Standby" android:textColor="@color/text_muted"
                            android:textSize="10sp" android:fontFamily="monospace"/>
                    </LinearLayout>
                    <!-- Chibi + badge -->
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="end">
                        <ImageView android:id="@+id/imgChibi"
                            android:layout_width="64dp" android:layout_height="64dp"
                            android:layout_gravity="center_horizontal"
                            android:src="@drawable/chibi_studying"
                            android:scaleType="fitCenter"/>
                        <TextView android:id="@+id/tvBadge"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="ALEXANDRIUS: STUDYING"
                            android:textSize="9sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:letterSpacing="0.05"
                            android:paddingHorizontal="10dp" android:paddingVertical="4dp"
                            android:background="@drawable/badge_bg"/>
                        <TextView android:id="@+id/tvAnchor"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="ANCHOR: 03:30" android:textColor="@color/text_muted"
                            android:textSize="9sp" android:fontFamily="monospace"
                            android:layout_gravity="end"/>
                    </LinearLayout>
                </LinearLayout>
                <!-- Load bar -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/barLoad"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:trackColor="@color/bg_log"
                    app:indicatorColor="@color/accent"
                    android:max="100"/>
                <!-- Lead text -->
                <TextView android:id="@+id/tvLead"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" android:gravity="center"
                    android:textSize="13sp" android:textStyle="bold"
                    android:fontFamily="monospace" android:letterSpacing="0.05"
                    android:textColor="@color/text_primary"/>
                <TextView android:id="@+id/tvDeficit"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" android:gravity="center"
                    android:textSize="9sp" android:textColor="@color/text_muted"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- VS card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="6dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <!-- User row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/imgUserPfp"
                        android:layout_width="56dp" android:layout_height="56dp"
                        android:layout_marginEnd="12dp"
                        app:civ_border_color="@color/good" app:civ_border_width="2dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="4dp">
                            <TextView android:id="@+id/tvUserName"
                                android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="YOU"
                                android:textColor="@color/text_primary" android:textSize="13sp"
                                android:textStyle="bold"/>
                            <TextView android:id="@+id/tvUserPasses"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="@color/good" android:textSize="13sp"
                                android:fontFamily="monospace" android:textStyle="bold"/>
                        </LinearLayout>
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/barUser"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            app:trackColor="@color/bg_log" app:indicatorColor="@color/good"
                            android:max="100"/>
                    </LinearLayout>
                </LinearLayout>
                <!-- VS divider -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="— VS —" android:gravity="center"
                    android:textColor="@color/bad" android:textSize="10sp"
                    android:textStyle="bold" android:layout_marginVertical="4dp"/>
                <!-- Rival row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/imgRivalPfp"
                        android:layout_width="56dp" android:layout_height="56dp"
                        android:layout_marginEnd="12dp"
                        app:civ_border_color="@color/accent" app:civ_border_width="2dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="4dp">
                            <TextView android:id="@+id/tvRivalName"
                                android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="ALEXANDRIUS"
                                android:textColor="@color/text_primary" android:textSize="13sp"
                                android:textStyle="bold"/>
                            <TextView android:id="@+id/tvRivalPasses"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="@color/accent" android:textSize="13sp"
                                android:fontFamily="monospace" android:textStyle="bold"/>
                        </LinearLayout>
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/barRival"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            app:trackColor="@color/bg_log" app:indicatorColor="@color/accent"
                            android:max="100"/>
                    </LinearLayout>
                </LinearLayout>
                <!-- Mini stats -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@color/bg_log" android:padding="8dp" android:gravity="center">
                        <TextView android:text="ALEX HRS" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/text_muted"
                            android:textSize="8sp"/>
                        <TextView android:id="@+id/tvAliciaHrs"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/warn" android:textSize="16sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <View android:layout_width="4dp" android:layout_height="match_parent"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@color/bg_log" android:padding="8dp" android:gravity="center">
                        <TextView android:text="ALEX PASSES" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/text_muted"
                            android:textSize="8sp"/>
                        <TextView android:id="@+id/tvAliciaPasses"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/accent" android:textSize="16sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <View android:layout_width="4dp" android:layout_height="match_parent"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@color/bg_log" android:padding="8dp" android:gravity="center">
                        <TextView android:id="@+id/tvBoostLabel" android:text="NO BOOST"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/text_muted" android:textSize="8sp"/>
                        <TextView android:id="@+id/tvBoost"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/text_muted" android:textSize="16sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Quip card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp" app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/imgRivalPfpSmall"
                    android:layout_width="40dp" android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_avatar_placeholder"/>
                <TextView android:id="@+id/tvQuip"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textColor="@color/text_primary"
                    android:textSize="12sp" android:textStyle="italic"
                    android:lineSpacingMultiplier="1.4"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Today's schedule -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="6dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:text="TODAY'S SCHEDULE"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/accent" android:textSize="11sp"
                    android:fontFamily="monospace" android:textStyle="bold"
                    android:letterSpacing="0.1" android:layout_marginBottom="10dp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvToday"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Streak overlay (floating bottom-right, overlaid via FrameLayout in parent activity) -->
        <TextView android:id="@+id/tvStreakOverlay"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:visibility="gone"
            android:gravity="center"
            android:textSize="22sp"
            android:background="@drawable/badge_bg"
            android:padding="8dp"/>

    </LinearLayout>
</ScrollView>
