<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/bg_nav"
    android:paddingVertical="12dp"
    android:paddingHorizontal="14dp"
    android:layout_marginBottom="2dp">

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView
            android:id="@+id/chapName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/chapCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <ImageButton
        android:id="@+id/chapBtnAdd"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="@drawable/btn_accent_circle"
        android:src="@drawable/ic_add"
        android:layout_marginEnd="8dp"
        android:contentDescription="Add topic"/>

    <TextView
        android:id="@+id/chapArrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="▼"
        android:textColor="@color/text_muted"
        android:textSize="11sp"/>

</LinearLayout>
