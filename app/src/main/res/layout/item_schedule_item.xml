<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/bg_log"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/siTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/siSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/siPassCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/warn"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <ImageButton
                android:id="@+id/siBtnAssign"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/btn_accent_circle"
                android:src="@drawable/ic_add"
                android:layout_marginEnd="4dp"
                android:contentDescription="Assign to day"/>

            <ImageButton
                android:id="@+id/siBtnDelete"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/btn_bad_circle"
                android:src="@drawable/ic_delete"
                android:contentDescription="Remove item"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/siProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progressTint="@color/accent"
            android:progressBackgroundTint="@color/border"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
