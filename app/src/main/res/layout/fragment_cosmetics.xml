<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Preset Themes -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:text="🎨 PRESET THEMES"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_muted" android:textSize="9sp"
                    android:fontFamily="monospace" android:letterSpacing="0.15"
                    android:textStyle="bold" android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button android:id="@+id/btnThemeNeon"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🌈 Neon Pulse"
                        android:textSize="10sp" android:backgroundTint="#1a1040"
                        android:layout_marginEnd="4dp"/>
                    <Button android:id="@+id/btnThemeOcean"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🌊 Ocean"
                        android:textSize="10sp" android:backgroundTint="#0c1a2e"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="8dp">
                    <Button android:id="@+id/btnThemeSunset"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🌅 Sunset"
                        android:textSize="10sp" android:backgroundTint="#2a0e00"
                        android:layout_marginEnd="4dp"/>
                    <Button android:id="@+id/btnThemeForest"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🌿 Forest"
                        android:textSize="10sp" android:backgroundTint="#052010"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Custom Accent -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:text="🖌 CUSTOM ACCENT COLOR"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_muted" android:textSize="9sp"
                    android:fontFamily="monospace" android:letterSpacing="0.15"
                    android:textStyle="bold" android:layout_marginBottom="12dp"/>

                <com.skydoves.colorpickerview.ColorPickerView
                    android:id="@+id/colorPicker"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"/>

                <TextView android:id="@+id/tvAccentHex"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/accent" android:textSize="13sp"
                    android:fontFamily="monospace" android:textStyle="bold"
                    android:gravity="center" android:layout_marginTop="8dp"/>

                <Button android:id="@+id/btnApplyAccent"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" android:text="Apply Accent Color"
                    android:backgroundTint="@color/bg_nav" android:textColor="@color/accent"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Particle Field -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="✨ PARTICLE FIELD"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/text_muted" android:textSize="9sp"
                            android:fontFamily="monospace" android:letterSpacing="0.15"
                            android:textStyle="bold"/>
                        <TextView android:text="Floating particles. Color shifts with your score."
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/text_muted" android:textSize="10sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <Switch android:id="@+id/swParticles"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:thumbTint="@color/accent" android:trackTint="@color/border"/>
                </LinearLayout>

                <TextView android:text="DENSITY" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textColor="@color/text_muted"
                    android:textSize="9sp" android:fontFamily="monospace"
                    android:letterSpacing="0.1" android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <RadioGroup android:id="@+id/rgDensity"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <RadioButton android:id="@+id/rbDensityLow"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Low"
                        android:textColor="@color/text_primary" android:buttonTint="@color/accent"/>
                    <RadioButton android:id="@+id/rbDensityMed"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Medium" android:checked="true"
                        android:textColor="@color/text_primary" android:buttonTint="@color/accent"/>
                    <RadioButton android:id="@+id/rbDensityHigh"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="High"
                        android:textColor="@color/text_primary" android:buttonTint="@color/accent"/>
                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Streak Effects -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="20dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="🔥 STREAK EFFECTS"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_muted" android:textSize="9sp"
                        android:fontFamily="monospace" android:letterSpacing="0.15"
                        android:textStyle="bold"/>
                    <TextView android:text="Flame badge grows with consecutive study days. Confetti at 7, 30, 100 days."
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_muted" android:textSize="10sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
                <Switch android:id="@+id/swStreak"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:thumbTint="@color/warn" android:trackTint="@color/border"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Smooth Animations -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="20dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="🎬 SMOOTH NUMBER ANIMATIONS"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_muted" android:textSize="9sp"
                        android:fontFamily="monospace" android:letterSpacing="0.15"
                        android:textStyle="bold"/>
                    <TextView android:text="Numbers animate when they update instead of jumping instantly."
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_muted" android:textSize="10sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
                <Switch android:id="@+id/swSmoothAnim"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:thumbTint="@color/accent" android:trackTint="@color/border"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
