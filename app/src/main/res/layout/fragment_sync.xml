<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp"
            app:cardElevation="6dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:text="💾 KERNEL SYNC"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_primary" android:textSize="13sp"
                    android:textStyle="bold" android:fontFamily="monospace"
                    android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <TextView android:text="Export your data as a backup, or import a previous backup to restore everything."
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_muted" android:textSize="10sp"
                    android:layout_marginBottom="20dp"/>

                <TextView android:id="@+id/tvSyncStatus"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/accent" android:textSize="11sp"
                    android:fontFamily="monospace" android:minHeight="32dp"
                    android:gravity="center_vertical" android:layout_marginBottom="16dp"
                    android:background="@color/bg_log" android:padding="10dp"/>

                <Button android:id="@+id/btnExport"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="💾 Export Backup"
                    android:backgroundTint="#1a2a4d" android:textColor="#90b8ff"
                    android:layout_marginBottom="10dp"/>

                <Button android:id="@+id/btnImport"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="📂 Import Backup"
                    android:backgroundTint="#1a2a4d" android:textColor="#90b8ff"
                    android:layout_marginBottom="20dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border" android:layout_marginBottom="20dp"/>

                <TextView android:text="⚠️ DANGER ZONE"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/bad" android:textSize="10sp"
                    android:textStyle="bold" android:fontFamily="monospace"
                    android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
                <TextView android:text="Purge all data — schedules, logs, history, and custom syllabi. Cannot be undone."
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_muted" android:textSize="10sp"
                    android:layout_marginBottom="12dp"/>

                <Button android:id="@+id/btnHardReset"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="⚠️ Purge All Data"
                    android:backgroundTint="@color/loss_bg" android:textColor="@color/bad"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
